# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class
*.so

# Packaging / build
*.egg-info/
*.egg
build/
dist/

# Virtual environments
.venv/
venv/
.env

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Experiment outputs default to results/; commit specific results if you
# want them in git, but the directory is not tracked by default.
results/

# Local tooling audit log (contains machine-specific absolute paths)
.pathwarden/

# Editor noise
.ipynb_checkpoints/
.vscode/
.idea/

# LaTeX build artifacts (regenerable from the .tex source)
*.aux
*.bbl
*.blg
*.log
*.out
*.synctex.gz
*.toc
*.fls
*.fdb_latexmk
paper/*.pdf

# Export bundles
*.zip

# OS noise
.DS_Store
Thumbs.db
